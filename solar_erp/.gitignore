# ============================================================================
# Solar ERP .gitignore - Cleaned and Organized
# ============================================================================

# ---- Build Artifacts (NEVER commit) ----
public/build.json
*.compiled
*.min.js
*.min.css

# ---- Python Cache ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ---- Backups ----
*.zip
backup_*/
backups/
*.bak
*.backup
*.disabled
*.disabled_temp
backup_*.zip

# ---- Logs ----
*.log
*.log.*

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Environment & Secrets ----
.env
.env.local
*.env

# ---- Node Modules ----
node_modules/

# ---- Documentation (tracked separately) ----
# Only ignore markdown files that are temporary notes/fixes
# README.md and INSTALLATION.md are tracked
*_FIX.md
*_SUMMARY.md
*_GUIDE.md
*_REFERENCE.md
ATOMIC_*.md
BUG_FIX_*.md
CRITICAL_*.md
LEAD_*.md
PROCUREMENT_*.md
WORKFLOW_*.md
VENDOR_*.md
PANEL_*.md
STRUCTURE_*.md
CHECKBOX_*.md
BROWSER_*.md

# ---- Emergency/One-Time Patches (NEVER commit) ----
# These are emergency fixes run directly on production
PATCH_*.py
patch_*.py
emergency_*.py
fix_*.py
disable_*.py
force_*.py
manual_*.py
rename_*.py
setup_execution_manager.py
add_vendor_column.py

# Root-level fix/setup scripts (should be in patches/ if needed)
/solar_erp/assign_gst_templates.py
/solar_erp/fix_brand_permissions.py
/solar_erp/fix_permissions.py
/solar_erp/fix_user_roles.py
/solar_erp/fix_workflow.py
/solar_erp/link_hsn_tax_templates.py
/solar_erp/make_territory_mandatory.py
/solar_erp/setup_purchase_gst.py
/solar_erp/setup_technical_survey.py

# ---- Development/Testing Scripts ----
scripts/
check_*.py
debug_*.py
verify_*.py
test_*.py
research_*.py
quick_check*.py
temp_*.py
auto_fix_*.py
supplier_query.py

# Specific test files
check_doctype_meta.py
check_vh_options.py
check_mc_custom_fields.py

# ---- ERPNext/Frappe Generated ----
patches.txt
hooks.py.backup

# ---- Other Apps (NEVER track) ----
solar_project/

# ---- IDE/Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/